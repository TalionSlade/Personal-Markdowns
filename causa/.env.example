# LLM provider (anthropic | mock)
CAUSA_LLM_PROVIDER=mock
CAUSA_LLM_MODEL=claude-3-5-sonnet-latest
CAUSA_LLM_TEMPERATURE=0.0

# Anthropic — only required when CAUSA_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Planning layer
CAUSA_WARM_START_PRIOR_SIZE=20
CAUSA_DOWHY_MIN_HISTORY=10
CAUSA_DOWHY_ESTIMATOR=linear_regression  # linear_regression | propensity_score | doubly_robust

# Reflection
CAUSA_REFLECTION_THRESHOLD=0.15
CAUSA_REFLECTION_SAMPLES=3

# Step budget per task (matches SWE-bench protocol)
CAUSA_STEP_BUDGET=12

# Trace output
CAUSA_TRACE_DIR=traces

# Eval
CAUSA_SWE_BENCH_CACHE=data/cache/swe-bench
CAUSA_BOOTSTRAP_ITERATIONS=1000
CAUSA_RANDOM_SEED=42
